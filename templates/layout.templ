package templates

templ Layout(title string) {
	<!DOCTYPE html>
	<html lang="ja">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title }</title>
			<link rel="stylesheet" href="/static/style.css"/>
		</head>
		<body>
			<header>
				<a href="/" class="site-title">ミニ日記（ゴママヨ）</a>
			</header>
			{ children... }
		</body>
	</html>
}
